{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@mariozechner/pi-coding-agent": ["/opt/homebrew/lib/node_modules/@mariozechner/pi-coding-agent"],
      "@mariozechner/pi-tui": ["/opt/homebrew/lib/node_modules/@mariozechner/pi-coding-agent/node_modules/@mariozechner/pi-tui"]
    },
    "typeRoots": [
      "/opt/homebrew/lib/node_modules/@mariozechner/pi-coding-agent/node_modules/@types"
    ]
  },
  "include": ["**/*.ts"]
}
